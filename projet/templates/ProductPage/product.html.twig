{% extends 'base.html.twig' %}

{% block title %}
    Produits
{% endblock %}

{% block body %}
    <h2>Produits disponibles : achetez les vite !</h2>

        <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Libellé</th>
                <th>Prix (€)</th>
                <th>Stock</th>
                <th>Choix</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.label }}</td>
                    <td>{{ product.unitPrice }}</td>
                    <td>{{ product.stock }}</td>
                    <td>
                        {% if product.stock > 0 %}
                            <select name="quantity_{{ product.id }}">
                                {% for i in 0..product.stock %}
                                    <option value="{{ i }}" {% if i == 0 %}selected{% endif %}>{{ i }}</option>
                                {% endfor %}
                            </select>
                        {% endif %}
                    </td>
                    <td>
                        {% if product.stock > 0 %}
                            <input type="button" value="Commander" />
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}