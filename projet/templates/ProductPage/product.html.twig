{% extends 'base.html.twig' %}

{% block title %}
    Produits
{% endblock %}

{% block body %}
    <h2>Produits disponibles : achetez les vite !</h2>

        <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Libellé</th>
                <th>Prix (€)</th>
                <th>Stock</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.label }}</td>
                    <td>{{ product.unitPrice }}</td>
                    <td>{{ product.stock }}</td>
                    <td>
                        {% if product.stock > 0 %}
                            {{ form_start(forms[product.id]) }}
                            {{ form_widget(forms[product.id].product_id) }}
                            {{ form_widget(forms[product.id].quantity) }}
                            <button type="submit">Commander</button>
                            {{ form_end(forms[product.id]) }}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}