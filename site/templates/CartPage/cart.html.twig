{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}

    <h2>Votre Panier</h2>
    
    {% if carts is empty %}
        <p>Le panier est vide ! Achetez vite un article !</p>
    {% else %}
        <table border="1" cellpadding="5">
            <thead>
                <tr>
                    <th>Libellé</th>
                    <th>Prix unitaire</th>
                    <th>Quantité</th>
                    <th>Prix total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for cart in carts %}
                    <tr>
                        <td>{{ cart.product.label }}</td>
                        <td>{{ cart.product.unitPrice }} €</td>
                        <td>{{ cart.quantity }}</td>
                        <td>{{ cart.product.unitPrice * cart.quantity }} €</td>
                        <td>
                            <a href="{{ path('cart_remove', {id: cart.id}) }}">Supprimer</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tr>
                <td></td>
                <td></td>
                <td>Total :</td>
                <td>{{ total }}</td>
                <td> euros</td>
            </tr>
        </table>
        
        <a href="{{ path('cart_clear') }}">Vider le panier</a>
        <a href="{{ path('cart_command') }}">Commander</a>
    {% endif %}
{% endblock %}